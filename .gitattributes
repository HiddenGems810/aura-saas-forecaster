# Normalize line endings across all platforms
* text=auto eol=lf

# Force LF for web source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.html text eol=lf

# Binary — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
